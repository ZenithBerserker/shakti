# ─── Database (Postgres — Neon, Supabase, or any host) ─────────────────────────
# Neon: pooled host for DATABASE_URL; **direct** (non-pooler) host for DIRECT_URL — migrations need this.
# Run migrations with: npm run db:migrate:deploy (loads .env + .env.local and strips channel_binding).
# If connections fail on Vercel, remove channel_binding=require from the URI (the app strips it at runtime too).
# Supabase serverless: transaction pooler on 6543 with ?pgbouncer=true — see Supabase dashboard.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct connection for migrations (non-pooled), from Neon “direct” connection string:
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Auth: customer sessions (HS256 JWT in httpOnly cookie) ──────────────────
JWT_SECRET="replace-with-long-random-string-min-16-chars"

# One-time create first admin via POST /api/admin/auth/bootstrap when zero admins exist (then delete from env).
ADMIN_BOOTSTRAP_SECRET=""

# ─── Firebase Admin (verify phone OTP idToken on server) ─────────────────────
# Firebase console → Project settings → Service accounts → Generate private key
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# ─── Firebase Web (browser OTP) ───────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=""
# Usually <PROJECT_ID>.firebaseapp.com — optional if NEXT_PUBLIC_FIREBASE_PROJECT_ID is set (app derives it).
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""

# ─── Supabase Storage (optional product image uploads) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
# Bucket name (create in Supabase Storage as "public"):
SUPABASE_PRODUCT_BUCKET="product-images"

# ─── Demo catalogue (no DATABASE_URL needed for storefront browse) ───────────
# Storefront auto-uses bundled SKUs when DATABASE_URL is empty or still contains [project-ref] etc.
# Force flags (optional): true | 1 | yes — restart dev after NEXT_PUBLIC_* changes; stale UI: rm -rf .next
NEXT_PUBLIC_USE_MOCK_CATALOG="false"
# USE_MOCK_CATALOG="false"

# ─── Commerce / UX toggles ───────────────────────────────────────────────────
DEFAULT_SHIPPING_FLAT="0"
NEXT_PUBLIC_LOW_STOCK_THRESHOLD="15"

# WhatsApp deep links (E.164 without + is fine; links strip non-digits)
NEXT_PUBLIC_SUPPORT_WHATSAPP="9198XXXXXXXX"
NEXT_PUBLIC_BUSINESS_WHATSAPP_ORDER="9198XXXXXXXX"
# Optional: separate warehouse / dispatch inbox for admin “WhatsApp draft” buttons (defaults to BUSINESS_WHATSAPP_ORDER)
NEXT_PUBLIC_DISPATCH_WHATSAPP="9198XXXXXXXX"

# Ops alerts when a customer order is placed (optional)
# POST JSON { event, orderNumber, grandTotal, delivery*, customerPhone } — e.g. Zapier / n8n / your worker
ORDER_NOTIFY_WEBHOOK_URL=""
# Twilio SMS (all four required to send). Body is a short fulfillment summary.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+1XXXXXXXXXX"
ORDER_ALERT_SMS_TO="+9198XXXXXXXX"
